@page "/battle"
@using System.Timers

<HudTop Hp="_hp" MaxHp="_maxHp" Mental="_mental" MaxMental="10" Level="_level" />

<div class="screen">
<div class="battle-screen">
    <div class="battle-header">
        <div class="battle-title">⚔️ 전투</div>
        <div class="battle-turn-badge">턴 @_turn</div>
    </div>

    <div class="battle-field">
        <!-- 적 -->
        <div>
            <div class="battle-side-label">적</div>
            <div class="battle-units">
                @foreach (var e in _enemies)
                {
                    <div class="battle-unit enemy @(e.IsActive ? "active" : "") @(e.Hp <= 0 ? "dead" : "")">
                        <div class="battle-unit-name">@e.Icon @e.Name</div>
                        <div class="battle-unit-hp">@e.Hp / @e.MaxHp</div>
                        <div class="unit-hp-bar">
                            <div class="unit-hp-bar-fill" style="width:@(e.Hp*100/e.MaxHp)%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="battle-divider">
            <div class="battle-divider-line"></div>
            <div class="battle-divider-icon">⚔️</div>
            <div class="battle-divider-line"></div>
        </div>

        <!-- 아군 -->
        <div>
            <div class="battle-side-label">아군</div>
            <div class="battle-units">
                @foreach (var a in _allies)
                {
                    <div class="battle-unit ally @(a.IsActive ? "active" : "") @(a.Hp <= 0 ? "dead" : "")">
                        <div class="battle-unit-name">@a.Icon @a.Name</div>
                        <div class="battle-unit-hp">@a.Hp / @a.MaxHp</div>
                        <div class="unit-hp-bar">
                            <div class="unit-hp-bar-fill" style="width:@(a.Hp*100/a.MaxHp)%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- 전투 로그 -->
    <div class="battle-log">
        @foreach (var log in _logs)
        {
            <div class="battle-log-entry @log.Cls">@log.Text</div>
        }
    </div>

    <!-- 행동 버튼 (플레이어 턴일 때) -->
    @if (_playerTurn && !_battleOver)
    {
        <div class="selections-panel">
            <div class="dice-display">
                @foreach (var d in _diceResult)
                {
                    <div class="dice @(_rolling ? "rolling" : "")">@d</div>
                }
            </div>
            <button class="selection-btn" @onclick="AttackAction">
                ⚔️ 공격하기
                <span class="selection-arrow">▶</span>
            </button>
            <button class="selection-btn" @onclick="DefendAction">
                🛡️ 방어하기
                <span class="selection-arrow">▶</span>
            </button>
            <button class="selection-btn" @onclick="FleeAction">
                🏃 도망치기
                <span class="selection-arrow">▶</span>
            </button>
        </div>
    }
    else if (!_battleOver)
    {
        <div class="event-advance-hint">⏳ 적의 차례...</div>
    }
</div>
</div>

<!-- 팝업 -->
<PopupOverlay Visible="_popupVisible" Title="_popupTitle" Message="_popupMsg"
              ConfirmText="확인" OnConfirm="ClosePopup" />

<!-- 게임 오버 -->
@if (_gameOver)
{
    <div class="gameover-overlay">
        <div class="gameover-title">GAME OVER</div>
        <div class="gameover-sub">당신은 쓰러졌다</div>
        <button class="gameover-retry" @onclick="Restart">다시 시작</button>
    </div>
}

@code {
    int _level = 3, _hp = 5, _maxHp = 6, _mental = 8, _turn = 1;
    bool _playerTurn = true, _battleOver, _gameOver, _popupVisible, _rolling;
    string _popupTitle = "", _popupMsg = "";
    int[] _diceResult = { 3, 5 };
    Random _rng = new();

    record BattleUnit(string Name, string Icon)
    {
        public int Hp    { get; set; }
        public int MaxHp { get; set; }
        public bool IsActive { get; set; }
    }

    List<BattleUnit> _enemies = new()
    {
        new BattleUnit("슬라임",     "🟢") { Hp = 8,  MaxHp = 8 },
        new BattleUnit("해골 전사",  "💀") { Hp = 12, MaxHp = 12 },
    };
    List<BattleUnit> _allies = new()
    {
        new BattleUnit("주인공",     "🧝") { Hp = 10, MaxHp = 10 },
        new BattleUnit("동료 마법사","🧙") { Hp = 7,  MaxHp = 8 },
    };

    List<(string Text, string Cls)> _logs = new()
    {
        ("전투가 시작되었다!", ""),
    };

    async Task AttackAction()
    {
        if (!_playerTurn) return;
        _rolling = true;
        _diceResult = new[] { _rng.Next(1, 7), _rng.Next(1, 7) };
        StateHasChanged();
        await Task.Delay(500);
        _rolling = false;

        int dmg = _diceResult.Sum();
        var target = _enemies.FirstOrDefault(e => e.Hp > 0);
        if (target != null)
        {
            target.Hp = Math.Max(0, target.Hp - dmg);
            AddLog($"🗡 주인공이 {target.Name}에게 {dmg} 피해! ({target.Hp}/{target.MaxHp})", "damage");
            if (target.Hp <= 0) AddLog($"✨ {target.Name} 처치!", "victory");
        }

        if (_enemies.All(e => e.Hp <= 0))
        {
            _battleOver = true;
            _popupTitle = "승리!"; _popupMsg = "모든 적을 물리쳤다. EXP +30";
            _popupVisible = true;
            return;
        }

        _playerTurn = false;
        await EnemyTurnAsync();
    }

    async Task DefendAction()
    {
        AddLog("🛡 방어 자세를 취했다. 다음 공격을 일부 흡수한다.", "");
        _playerTurn = false;
        await EnemyTurnAsync();
    }

    void FleeAction()
    {
        bool success = _rng.Next(0, 2) == 0;
        if (success) { _popupTitle = "도주 성공"; _popupMsg = "간신히 도망쳤다."; }
        else         { _popupTitle = "도주 실패"; _popupMsg = "적이 막아섰다!"; }
        _popupVisible = true;
        _battleOver   = true;
    }

    async Task EnemyTurnAsync()
    {
        await Task.Delay(800);
        foreach (var e in _enemies.Where(e => e.Hp > 0))
        {
            var t = _allies.Where(a => a.Hp > 0).OrderBy(_ => _rng.Next()).FirstOrDefault();
            if (t == null) break;
            int dmg = _rng.Next(1, 5);
            t.Hp = Math.Max(0, t.Hp - dmg);
            if (t.Name == "주인공") _hp = Math.Max(0, _hp - 1);
            AddLog($"💢 {e.Name}이 {t.Name}에게 {dmg} 피해!", "damage");
        }

        _turn++;
        _playerTurn = true;
        StateHasChanged();

        if (_hp <= 0 || _allies.All(a => a.Hp <= 0))
        {
            await Task.Delay(300);
            _gameOver = true;
            StateHasChanged();
        }
    }

    void AddLog(string text, string cls)
    {
        _logs.Add((text, cls));
        if (_logs.Count > 10) _logs.RemoveAt(0);
        StateHasChanged();
    }

    void ClosePopup() { _popupVisible = false; }
    void Restart()
    {
        _enemies.ForEach(e => { e.Hp = e.MaxHp; e.IsActive = false; });
        _allies.ForEach(a => { a.Hp = a.MaxHp; a.IsActive = false; });
        _hp = 5; _turn = 1; _playerTurn = true; _battleOver = false; _gameOver = false;
        _logs.Clear(); AddLog("전투가 다시 시작되었다!", "");
    }
}
