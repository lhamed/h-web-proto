@page "/battle"
@inject GameDataService GDS
@inject GameStateService GSS
@inject NavigationManager Nav

<HudTop Hp="@GSS.Hp" MaxHp="@GSS.MaxHp" Mental="@GSS.Mental" MaxMental="@GSS.MaxMental" Level="@GSS.Level" />

<div class="screen">
<div class="battle-screen">
    <div class="battle-header">
        <div class="battle-title">⚔️ 전투</div>
        <div class="battle-turn-badge">턴 @_turn</div>
    </div>

    <div class="battle-field">
        <div>
            <div class="battle-side-label">적</div>
            <div class="battle-units">
                @foreach (var e in _enemies)
                {
                    <div class="battle-unit enemy @(e.IsActive?"active":"") @(e.Hp<=0?"dead":"")">
                        <div class="battle-unit-name">👾 @e.Name</div>
                        <div class="battle-unit-hp">@e.Hp / @e.MaxHp</div>
                        <div class="unit-hp-bar">
                            <div class="unit-hp-bar-fill" style="width:@(e.MaxHp>0?e.Hp*100/e.MaxHp:0)%"></div>
                        </div>
                    </div>
                }
                @if (_enemies.Count == 0)
                {
                    <div style="color:var(--text-muted);font-size:13px">적 정보 없음</div>
                }
            </div>
        </div>

        <div class="battle-divider">
            <div class="battle-divider-line"></div>
            <div class="battle-divider-icon">⚔️</div>
            <div class="battle-divider-line"></div>
        </div>

        <div>
            <div class="battle-side-label">아군</div>
            <div class="battle-units">
                <div class="battle-unit ally @(_playerActive?"active":"") @(GSS.Hp<=0?"dead":"")">
                    <div class="battle-unit-name">🧝 플레이어</div>
                    <div class="battle-unit-hp">@GSS.Hp / @GSS.MaxHp</div>
                    <div class="unit-hp-bar">
                        <div class="unit-hp-bar-fill" style="width:@(GSS.MaxHp>0?GSS.Hp*100/GSS.MaxHp:0)%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="battle-log">
        @foreach (var log in _logs)
        {
            <div class="battle-log-entry @log.Cls">@log.Text</div>
        }
    </div>

    @if (_playerTurn && !_battleOver)
    {
        <div class="selections-panel">
            <div class="dice-display">
                @foreach (var d in _diceResult)
                {
                    <div class="dice @(_rolling?"rolling":"")">@d</div>
                }
            </div>
            <button class="selection-btn" @onclick="AttackAction">⚔️ 공격 <span class="selection-arrow">▶</span></button>
            <button class="selection-btn" @onclick="DefendAction">🛡️ 방어 <span class="selection-arrow">▶</span></button>
            <button class="selection-btn" @onclick="FleeAction">🏃 도망 <span class="selection-arrow">▶</span></button>
        </div>
    }
    else if (!_battleOver)
    {
        <div class="event-advance-hint">⏳ 적의 차례...</div>
    }
    else
    {
        <div class="selections-panel">
            <button class="selection-btn" @onclick="EndBattle">계속 → <span class="selection-arrow">▶</span></button>
        </div>
    }
</div>
</div>

<PopupOverlay Visible="_popupVisible" Title="@_popupTitle" Message="@_popupMsg"
              ConfirmText="확인" OnConfirm="() => _popupVisible = false" />

@if (GSS.IsGameOver)
{
    <div class="gameover-overlay">
        <div class="gameover-title">GAME OVER</div>
        <div class="gameover-sub">전투에서 쓰러졌다</div>
        <button class="gameover-retry" @onclick="GoToDefeat">계속</button>
    </div>
}

@code {
    class BattleUnit
    {
        public string Name   { get; set; } = "";
        public int    Hp     { get; set; }
        public int    MaxHp  { get; set; }
        public int    Faces  { get; set; } = 6;
        public int    Count  { get; set; } = 1;
        public bool   IsActive { get; set; }
    }

    List<BattleUnit> _enemies = new();
    List<(string Text, string Cls)> _logs = new();
    int[]  _diceResult = { 1 };
    int    _turn = 1;
    bool   _playerTurn = true, _battleOver, _rolling, _victory;
    bool   _popupVisible, _playerActive;
    string _popupTitle = "", _popupMsg = "";
    Random _rng = new();

    protected override void OnInitialized() => SetupBattle();

    void SetupBattle()
    {
        _enemies.Clear(); _logs.Clear();
        _turn = 1; _playerTurn = true; _battleOver = false; _victory = false;

        // EXPORTED.bytes 데이터로 전투 구성
        if (GDS.IsLoaded && GSS.PendingBattleKey > 0)
        {
            var battle = GDS.GetBattle(GSS.PendingBattleKey);
            if (battle != null)
            {
                var group = GDS.GetMonsterGroup(battle.MonsterGroupKey);
                if (group != null)
                {
                    foreach (var mKey in group.MemberKeys)
                    {
                        var unit = GDS.GetUnit(mKey);
                        if (unit == null) continue;
                        var dice = unit.AttackDiceKey > 0 ? GDS.GetDice(unit.AttackDiceKey) : null;
                        _enemies.Add(new BattleUnit
                        {
                            Name  = GDS.L(unit.NameKey),
                            Hp    = unit.MaxHP, MaxHp = unit.MaxHP,
                            Faces = dice?.Faces ?? 6, Count = dice?.Count ?? 1
                        });
                    }
                }
            }
        }

        // 데이터 없으면 기본 적 2명
        if (_enemies.Count == 0)
        {
            _enemies.Add(new BattleUnit { Name = "슬라임",    Hp = 8,  MaxHp = 8  });
            _enemies.Add(new BattleUnit { Name = "해골 전사", Hp = 12, MaxHp = 12, Faces = 8 });
        }

        // 플레이어 공격 주사위
        var playerUnit = GDS.IsLoaded && GDS.Data!.GameUnits.Count > 0 ? GDS.Data!.GameUnits[0] : null;
        var pDice = playerUnit?.AttackDiceKey > 0 ? GDS.GetDice(playerUnit.AttackDiceKey) : null;
        _diceResult = new int[pDice?.Count ?? 2];
        for (int i = 0; i < _diceResult.Length; i++) _diceResult[i] = _rng.Next(1, (pDice?.Faces ?? 6) + 1);

        AddLog("전투 시작!", "");
    }

    async Task AttackAction()
    {
        if (!_playerTurn) return;
        _rolling = true;
        for (int i = 0; i < _diceResult.Length; i++)
            _diceResult[i] = _rng.Next(1, 7);
        StateHasChanged();
        await Task.Delay(500);
        _rolling = false;

        int dmg = 0;
        foreach (var d in _diceResult) dmg += d;

        var target = _enemies.FirstOrDefault(e => e.Hp > 0);
        if (target != null)
        {
            target.Hp = Math.Max(0, target.Hp - dmg);
            AddLog($"🗡 {dmg} 피해 → {target.Name} ({target.Hp}/{target.MaxHp})", "damage");
            if (target.Hp <= 0)
            {
                AddLog($"✨ {target.Name} 처치!", "victory");
                GSS.ApplyEffect(new HWebProto.Models.EffectDto { DataType = "Exp", Op = "Add", Value = 20 });
            }
        }

        if (_enemies.All(e => e.Hp <= 0))
        {
            AddLog("🏆 승리!", "victory");
            _battleOver = true; _victory = true;
            return;
        }
        _playerTurn = false;
        _playerActive = false;
        await EnemyTurnAsync();
    }

    async Task DefendAction()
    {
        AddLog("🛡 방어 자세. 다음 피해 -2.", "");
        _playerTurn = false;
        await EnemyTurnAsync();
    }

    async Task FleeAction()
    {
        bool ok = _rng.Next(2) == 0;
        AddLog(ok ? "🏃 도주 성공!" : "❌ 도주 실패!", ok ? "victory" : "damage");
        if (ok) { _battleOver = true; }
        else    { _playerTurn = false; await EnemyTurnAsync(); }
    }

    async Task EnemyTurnAsync()
    {
        await Task.Delay(700);
        foreach (var e in _enemies.Where(e => e.Hp > 0))
        {
            e.IsActive = true; StateHasChanged();
            await Task.Delay(300);
            int dmg = 0;
            for (int i = 0; i < e.Count; i++) dmg += _rng.Next(1, e.Faces + 1);
            GSS.ApplyEffect(new HWebProto.Models.EffectDto { DataType = "HP", Op = "Subtract", Value = dmg });
            AddLog($"💢 {e.Name} → 플레이어 {dmg} 피해", "damage");
            e.IsActive = false;
            if (GSS.IsGameOver) break;
        }
        _turn++;
        _playerTurn = true; _playerActive = true;
        StateHasChanged();
    }

    void EndBattle()
    {
        if (_victory && GSS.VictoryEventKey > 0)
        {
            GSS.CurrentEventKey = GSS.VictoryEventKey;
            Nav.NavigateTo("event");
        }
        else Nav.NavigateTo("");
    }

    void GoToDefeat()
    {
        if (GSS.DefeatEventKey > 0)
        {
            GSS.CurrentEventKey = GSS.DefeatEventKey;
            Nav.NavigateTo("event");
        }
        else Nav.NavigateTo("");
    }

    void AddLog(string text, string cls)
    {
        _logs.Add((text, cls));
        if (_logs.Count > 12) _logs.RemoveAt(0);
        StateHasChanged();
    }
}
