@page "/event"
@inject GameDataService GDS
@inject GameStateService GSS
@inject NavigationManager Nav

<HudTop Hp="@GSS.Hp" MaxHp="@GSS.MaxHp" Mental="@GSS.Mental" MaxMental="@GSS.MaxMental" Level="@GSS.Level" />

<div class="screen">
@if (_event == null)
{
    <div style="padding:40px 20px;text-align:center;color:var(--text-dim)">
        <div style="font-size:32px;margin-bottom:10px">📭</div>
        @if (!GDS.IsLoaded)
        {
            <div>데이터가 없습니다.</div>
            <a href="/import" style="color:var(--accent)">데이터 불러오기 →</a>
        }
        else
        {
            <div>진행할 이벤트가 없습니다.</div>
            <a href="/" style="color:var(--accent)">홈으로 →</a>
        }
    </div>
}
else
{
<div class="event-screen">
    <!-- 배경 씬 -->
    <div class="event-bg" @onclick="Advance" style="cursor:pointer">
        <div class="event-bg-overlay"></div>
        <div class="event-scene-label">📍 이벤트 #@_event.Key</div>
        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-60%);font-size:80px;opacity:0.12;pointer-events:none;user-select:none">
            @_sceneBgIcon
        </div>
    </div>

    <!-- 콘텐츠 패널 -->
    <div class="event-content-panel">
        <div class="event-scroll-area" @ref="_scrollArea">
            @foreach (var item in _visibleItems)
            {
                @if (item.Type == "Narration")
                {
                    <div class="narration-text">
                        @item.DisplayText
                        @if (!item.Done) { <span class="typewriter-cursor"></span> }
                    </div>
                }
                else if (item.Type == "Dialogue")
                {
                    <div class="dialogue-box">
                        <div class="dialogue-portrait">@item.Portrait</div>
                        <div class="dialogue-bubble">
                            <div class="dialogue-speaker">@item.Speaker</div>
                            <div class="dialogue-text">
                                @item.DisplayText
                                @if (!item.Done) { <span class="typewriter-cursor"></span> }
                            </div>
                        </div>
                    </div>
                }
                else if (item.Type == "Image")
                {
                    <div class="image-content" style="font-size:60px">🖼</div>
                }
            }
        </div>
        @if (!_allDone && !_showSelections)
        {
            <div class="event-advance-hint">▼ 화면을 탭하세요</div>
        }
    </div>

    <!-- 선택지 -->
    @if (_showSelections && _block != null)
    {
        <div class="selections-panel">
            @foreach (var sel in _block.Selections)
            {
                var s = sel;
                <button class="selection-btn" @onclick="() => ChooseSelection(s)">
                    @GDS.L(s.SelectionTextKey)
                    <span class="selection-arrow">▶</span>
                </button>
            }
            @if (_block.Selections.Count == 0)
            {
                <button class="selection-btn" @onclick="AdvanceBlock">
                    계속 →
                    <span class="selection-arrow">▶</span>
                </button>
            }
        </div>
    }
</div>
}
</div>

<!-- 결과 팝업 -->
<PopupOverlay Visible="_popupVisible"
              Title="@_popupTitle" Message="@_popupMsg"
              ConfirmText="확인" OnConfirm="AfterPopup" />

<!-- 게임 오버 -->
@if (GSS.IsGameOver)
{
    <div class="gameover-overlay">
        <div class="gameover-title">GAME OVER</div>
        <div class="gameover-sub">쓰러졌다...</div>
        <button class="gameover-retry" @onclick='() => Nav.NavigateTo("")'>처음으로</button>
    </div>
}

@code {
    record VisibleItem(string Type, string DisplayText, string Speaker = "", string Portrait = "", bool Done = false);

    HWebProto.Models.GameEventDto?      _event;
    HWebProto.Models.ContentBlockDto?   _block;
    List<VisibleItem> _visibleItems = new();
    int  _blockIdx, _itemIdx;
    bool _showSelections, _popupVisible, _allDone;
    string _popupTitle = "", _popupMsg = "", _sceneBgIcon = "🌙";
    long _nextEventKey;
    Microsoft.AspNetCore.Components.ElementReference _scrollArea;

    static readonly string[] _bgIcons = { "🌙","🏚","🏮","⛩","🌲","🏔","🌊","🏜","🗡","🔥" };
    static readonly Random _rng = new();

    protected override void OnInitialized() => LoadEvent(GSS.CurrentEventKey);

    void LoadEvent(long key)
    {
        _event = GDS.IsLoaded ? GDS.GetEvent(key) : null;
        if (_event == null && !GDS.IsLoaded)
        {
            // 데모 이벤트 사용
            LoadDemoEvent();
            return;
        }
        if (_event == null) return;

        // 조건 체크 → 조건 만족하는 첫 번째 이벤트
        bool condOk = (_event.Conditions?.Count ?? 0) == 0
                   || _event.Conditions!.All(c => GSS.CheckCondition(c));
        if (!condOk) { _event = null; return; }

        _sceneBgIcon = _bgIcons[_rng.Next(_bgIcons.Length)];
        _blockIdx = 0; _itemIdx = 0;
        _showSelections = false; _allDone = false;
        _visibleItems.Clear();
        LoadBlock();
    }

    void LoadBlock()
    {
        if (_event == null || _blockIdx >= _event.ContentBlocks.Count)
        {
            _showSelections = false; _allDone = true;
            return;
        }
        _block = _event.ContentBlocks[_blockIdx];
        _itemIdx = 0;
        ShowNextItem();
    }

    void ShowNextItem()
    {
        if (_block == null) return;
        if (_itemIdx >= _block.ContentItems.Count)
        {
            // 블록 끝 → 선택지 표시
            _showSelections = true;
            return;
        }
        var raw = _block.ContentItems[_itemIdx];
        string text = GDS.L(raw.TextKey);
        string speaker = GDS.L(raw.SpeakerNameKey);
        _visibleItems.Add(new VisibleItem(raw.Type, text, speaker, "🧑", Done: false));
        _itemIdx++;
        _ = MarkDoneAsync(_visibleItems.Count - 1);
    }

    async Task MarkDoneAsync(int idx)
    {
        int ms = Math.Min(_visibleItems[idx].DisplayText.Length * 35, 1800);
        await Task.Delay(ms);
        if (idx < _visibleItems.Count)
            _visibleItems[idx] = _visibleItems[idx] with { Done = true };
        StateHasChanged();
    }

    void Advance()
    {
        if (_showSelections) return;
        var last = _visibleItems.LastOrDefault();
        if (last != null && !last.Done)
        {
            _visibleItems[^1] = last with { Done = true };
        }
        else
        {
            ShowNextItem();
        }
    }

    void ChooseSelection(HWebProto.Models.SelectionDto sel)
    {
        _showSelections = false;

        // 공통 이펙트 적용
        foreach (var e in _block?.CommonEffects ?? new())
            if (!IsBattleEffect(e)) GSS.ApplyEffect(e);
        // 선택지 이펙트 적용
        foreach (var e in sel.Effects ?? new())
            if (!IsBattleEffect(e)) GSS.ApplyEffect(e);

        string resultText = GDS.L(sel.ResultTextKey);

        long battleKey = GetBattleKey(sel);
        if (battleKey > 0 || sel.BattleVictoryEventKey > 0 || sel.BattleDefeatEventKey > 0)
        {
            // 전투 이벤트로 전환
            GSS.PendingBattleKey = battleKey > 0 ? battleKey : GDS.FirstBattleKey();
            GSS.VictoryEventKey = sel.BattleVictoryEventKey;
            GSS.DefeatEventKey  = sel.BattleDefeatEventKey;
            if (!string.IsNullOrEmpty(resultText))
            {
                _popupTitle = "전투 시작"; _popupMsg = resultText; _popupVisible = true;
                _nextEventKey = -1; // 팝업 후 전투로
            }
            else
            {
                Nav.NavigateTo("battle");
            }
            return;
        }

        if (!string.IsNullOrEmpty(resultText))
        {
            _popupTitle = "결과";
            _popupMsg   = resultText;
            _popupVisible = true;
            _nextEventKey = 0;
        }
        else
        {
            AdvanceBlock();
        }
    }

    static bool IsBattleEffect(HWebProto.Models.EffectDto effect)
        => string.Equals(effect.DataType, "Battle", StringComparison.OrdinalIgnoreCase);

    static long GetBattleKey(HWebProto.Models.SelectionDto selection)
        => selection.Effects?.FirstOrDefault(IsBattleEffect)?.DataKey ?? 0;

    void AdvanceBlock()
    {
        _blockIdx++;
        _visibleItems.Clear();
        _showSelections = false;
        LoadBlock();
    }

    void AfterPopup()
    {
        _popupVisible = false;
        if (_nextEventKey == -1)
        {
            Nav.NavigateTo("battle");
            return;
        }
        if (_allDone || _event?.ContentBlocks.Count <= _blockIdx + 1)
        {
            // 다음 이벤트 결정
            long next = ResolveNextEvent();
            if (next > 0)
            {
                GSS.CurrentEventKey = next;
                LoadEvent(next);
            }
            else
            {
                // 이벤트 체인 종료 → 홈
                Nav.NavigateTo("");
            }
        }
        else
        {
            AdvanceBlock();
        }
    }

    long ResolveNextEvent()
    {
        if (_event == null) return 0;
        return _event.NextEventMode switch
        {
            "First"           => _event.NextEventKeys?.FirstOrDefault() ?? 0,
            "Random"          => _event.NextEventKeys?.Count > 0
                                 ? _event.NextEventKeys[_rng.Next(_event.NextEventKeys.Count)]
                                 : 0,
            "ConditionalList" => _event.NextEventEntries?
                                     .FirstOrDefault(e => e.Conditions.All(c => GSS.CheckCondition(c)))
                                     ?.EventKey ?? 0,
            _                 => _event.NextEventKeys?.FirstOrDefault() ?? 0
        };
    }

    // 데모 이벤트 (데이터 없을 때)
    void LoadDemoEvent()
    {
        _visibleItems.Clear();
        _showSelections = false; _allDone = false;
        _sceneBgIcon = "🏚";
        _visibleItems.Add(new VisibleItem("Narration",
            "삐걱거리는 복도를 걷다 방문 앞에서 멈춘다. 문 아래로 희미한 빛이 새어나온다.", Done: false));
        _ = MarkDoneAsync(0);
    }
}
