@page "/import"
@inject GameDataService GDS
@inject GameStateService GSS
@inject NavigationManager Nav
@inject HttpClient Http

<div class="screen">
<div style="padding:28px 20px;display:flex;flex-direction:column;gap:20px;min-height:100%">

    <div style="text-align:center;padding-top:20px">
        <div style="font-size:48px;margin-bottom:12px">📦</div>
        <div style="font-size:20px;font-weight:700;color:var(--text)">게임 데이터 불러오기</div>
        <div style="font-size:13px;color:var(--text-muted);margin-top:6px;line-height:1.6">
            H-Editor 또는 Unity에서 내보낸<br/>
            <strong style="color:var(--accent)">EXPORTED.bytes</strong> 파일을 선택하세요
        </div>
        @if (GDS.IsMasterDataLoaded)
        {
            <div style="font-size:12px;color:var(--success);margin-top:8px">
                M.bytes 자동 로드됨 · @GDS.MasterDataFileName
            </div>
        }
    </div>

    <!-- 파일 선택 영역 -->
    <div style="border:2px dashed @(_dragging?"var(--accent)":"var(--border)");border-radius:16px;padding:32px 20px;text-align:center;transition:border-color 0.2s;background:@(_dragging?"var(--accent-dim)":"transparent")"
         @ondragover:preventDefault="true"
         @ondragover="() => _dragging = true"
         @ondragleave="() => _dragging = false"
         @ondrop="OnDrop" @ondrop:preventDefault="true">
        <div style="font-size:32px;margin-bottom:10px">📂</div>
        <div style="font-size:13px;color:var(--text-dim);margin-bottom:14px">파일을 드래그하거나 버튼을 클릭하세요</div>
        <InputFile OnChange="OnFileSelected" accept=".bytes,.json" style="display:none" id="fileInput" />
        <label for="fileInput" class="game-btn" style="display:inline-block;cursor:pointer">
            파일 선택
        </label>
    </div>

    @if (_error != null)
    {
        <div style="background:rgba(232,69,69,0.1);border:1px solid rgba(232,69,69,0.3);border-radius:var(--radius);padding:12px 14px;color:var(--danger);font-size:13px">
            ⚠️ @_error
        </div>
    }

    @if (_loading)
    {
        <div style="text-align:center;padding:20px">
            <div class="splash-dots" style="justify-content:center">
                <span></span><span></span><span></span>
            </div>
            <div style="margin-top:10px;font-size:13px;color:var(--text-dim)">파싱 중...</div>
        </div>
    }

    @if (GDS.IsLoaded && !_loading)
    {
        var d = GDS.Data!;
        <div style="background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.25);border-radius:var(--radius);padding:14px">
            <div style="font-size:12px;font-weight:700;color:var(--success);margin-bottom:10px">✅ 로드 완료 · v@(d.Version)</div>
            @if (!string.IsNullOrEmpty(GDS.LoadedFileName))
            {
                <div style="font-size:12px;color:var(--text-dim);margin-bottom:10px">파일: <strong style="color:var(--text)">@GDS.LoadedFileName</strong></div>
            }
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">
                @foreach (var (label, count) in new (string,int)[] {
                    ("이벤트", d.GameEvents.Count),
                    ("아이템", d.GameItems.Count),
                    ("유닛",   d.GameUnits.Count),
                    ("몬스터", d.MonsterDatas.Count),
                    ("주사위", d.DiceDatas.Count),
                    ("몬스터 그룹", d.MonsterGroups.Count),
                    ("전투",  d.BattleDatas.Count),
                })
                {
                    <div style="font-size:12px;color:var(--text-dim)">@label <strong style="color:var(--text)">@count</strong></div>
                }
            </div>
        </div>

        <button class="game-btn" style="width:100%;padding:14px;font-size:15px" @onclick="StartGame">
            🎮 게임 시작
        </button>
    }

    @if (!GDS.IsLoaded)
    {
        <div style="border-top:1px solid var(--border);padding-top:16px">
            <div style="font-size:12px;color:var(--text-muted);text-align:center;line-height:1.6">
                업로드한 데이터가 있어야 게임을 시작합니다.
            </div>
        </div>
    }

</div>
</div>

@code {
    bool _dragging, _loading;
    string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (GDS.IsMasterDataLoaded) return;

        try
        {
            var cacheBust = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            var bytes = await Http.GetByteArrayAsync($"data/M.bytes?v={cacheBust}");
            GDS.LoadMasterData(bytes);
        }
        catch
        {
            // M.bytes는 EXPORTED.bytes 업로드 없이도 텍스트 최신화를 돕는 선택 리소스입니다.
        }
    }

    async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _error = null; _loading = true; StateHasChanged();
        await Task.Yield();
        try
        {
            using var ms = new System.IO.MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 10_000_000).CopyToAsync(ms);
            GDS.Load(ms.ToArray(), e.File.Name, userLoaded: true);
            GSS.InitFromData(GDS);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    async Task OnDrop(DragEventArgs e)
    {
        _dragging = false;
        // Blazor WASM에서 drag-drop 파일은 InputFile 없이는 접근 불가 — 안내만 표시
        _error = "드래그 앤 드롭은 현재 지원되지 않습니다. '파일 선택' 버튼을 이용하세요.";
        await Task.CompletedTask;
    }

    void StartGame()
    {
        if (GDS.IsLoaded)
            Nav.NavigateTo("game");
    }
}
