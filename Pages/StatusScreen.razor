@page "/status"
@inject GameDataService GDS
@inject GameStateService GSS
@implements IDisposable

<HudTop Hp="@GSS.Hp" MaxHp="@GSS.MaxHp" Mental="@GSS.Mental" MaxMental="@GSS.MaxMental" Level="@GSS.Level" />

<div class="screen">
<div class="status-screen">
    <div class="status-avatar">🧝</div>
    @if (GDS.IsLoaded && GDS.Data!.GameUnits.Count > 0)
    {
        <div class="status-name">@GDS.L(GDS.Data!.GameUnits[0].NameKey)</div>
    }
    else
    {
        <div class="status-name">플레이어</div>
    }
    <div class="status-class">모험가 · Lv.@GSS.Level</div>

    <!-- 바이탈 -->
    <div class="section-title">바이탈</div>
    <div style="margin-bottom:14px">
        <div class="vitals-bar-row">
            <span class="vitals-bar-label">HP</span>
            <div class="vitals-bar-track">
                <div class="vitals-bar-fill hp" style="width:@(GSS.MaxHp>0?GSS.Hp*100/GSS.MaxHp:0)%"></div>
            </div>
            <span class="vitals-bar-num">@GSS.Hp / @GSS.MaxHp</span>
        </div>
        <div class="vitals-bar-row">
            <span class="vitals-bar-label">정신력</span>
            <div class="vitals-bar-track">
                <div class="vitals-bar-fill mental" style="width:@(GSS.MaxMental>0?GSS.Mental*100/GSS.MaxMental:0)%"></div>
            </div>
            <span class="vitals-bar-num">@GSS.Mental / @GSS.MaxMental</span>
        </div>
        <div class="vitals-bar-row">
            <span class="vitals-bar-label">경험치</span>
            <div class="vitals-bar-track">
                <div class="vitals-bar-fill exp" style="width:@(GSS.NextExp>0?GSS.Exp*100/GSS.NextExp:0)%"></div>
            </div>
            <span class="vitals-bar-num">@GSS.Exp / @GSS.NextExp</span>
        </div>
    </div>

    <!-- 스탯 -->
    <div class="section-title">
        스탯
        @if (GSS.FreePoints > 0)
        {
            <span class="tag tag-gold" style="margin-left:6px">잔여 @(GSS.FreePoints)pt</span>
        }
    </div>
    <div class="stat-grid">
        @foreach (var stat in _statDefs)
        {
            var s = stat;
            int val = s.Get(GSS);
            <div class="stat-card">
                <div class="stat-icon">@s.Icon</div>
                <div style="flex:1">
                    <div class="stat-label">@s.Name</div>
                    <div class="stat-value">@val</div>
                </div>
                <button class="stat-invest-btn" @onclick="() => Invest(s.Key)" disabled="@(GSS.FreePoints<=0)">+</button>
            </div>
        }
    </div>

    <!-- 장착 장비 요약 -->
    @if (GSS.Equipment.Count > 0 && GDS.IsLoaded)
    {
        <div class="section-title">장착 장비</div>
        <div style="background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius);padding:10px 12px;display:flex;flex-direction:column;gap:6px">
            @foreach (var (slot, itemKey) in GSS.Equipment)
            {
                var item = GDS.GetItem(itemKey);
                if (item == null) continue;
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <span style="font-size:11px;color:var(--text-muted)">@slot</span>
                    <span style="font-size:12px;color:var(--text)">@GDS.L(item.NameKey)</span>
                </div>
            }
        </div>
    }

    <div style="height:16px"></div>
</div>
</div>

<PopupOverlay Visible="_popupVisible" Title="레벨 업!" Message="@_popupMsg"
              ConfirmText="계속" OnConfirm="() => _popupVisible = false" />

@code {
    bool _popupVisible;
    string _popupMsg = "";
    int _prevLevel;

    record StatDef(string Key, string Name, string Icon, Func<GameStateService, int> Get);
    readonly StatDef[] _statDefs =
    {
        new("Mental",    "정신력", "M", g => g.MentalStat),
        new("Vitality",  "체력",   "V", g => g.Vitality),
        new("Strength",  "완력",   "S", g => g.Strength),
        new("Dexterity", "민첩성", "D", g => g.Dexterity),
    };

    protected override void OnInitialized()
    {
        _prevLevel = GSS.Level;
        GSS.OnStateChanged += OnGSSChanged;
    }

    void OnGSSChanged()
    {
        if (GSS.Level > _prevLevel)
        {
            _popupMsg     = $"레벨 {GSS.Level}이 되었습니다!\n능력치 포인트 +2";
            _popupVisible = true;
            _prevLevel    = GSS.Level;
        }
        StateHasChanged();
    }

    void Invest(string statKey)
    {
        GSS.InvestStat(statKey);
    }

    public void Dispose() => GSS.OnStateChanged -= OnGSSChanged;
}
