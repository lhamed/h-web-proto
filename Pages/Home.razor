@page "/"
@inject GameDataService GDS
@inject GameStateService GSS
@inject NavigationManager Nav

<HudTop Hp="@GSS.Hp" MaxHp="@GSS.MaxHp" Mental="@GSS.Mental" MaxMental="@GSS.MaxMental" Level="@GSS.Level" />

<div class="screen">
    @if (!GDS.IsLoaded)
    {
        <!-- 데이터 미로드 상태 -->
        <div style="padding:40px 20px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:20px">
            <div style="font-size:60px">🏰</div>
            <div>
                <div style="font-size:22px;font-weight:700;letter-spacing:4px;color:var(--accent)">HOHEUP</div>
                <div style="font-size:12px;color:var(--text-muted);letter-spacing:2px;margin-top:4px">Web Prototype</div>
            </div>
            <div style="font-size:14px;color:var(--text-dim);line-height:1.7;max-width:280px;text-align:center">
                H-Editor에서 내보낸 <strong style="color:var(--accent)">EXPORTED.bytes</strong>를 불러오면 실제 게임 데이터로 플레이할 수 있습니다.
            </div>
            <button class="game-btn" style="width:220px;padding:14px;font-size:15px" @onclick='() => Nav.NavigateTo("/import")'>
                📦 데이터 불러오기
            </button>
            <div style="border-top:1px solid var(--border);padding-top:16px;width:100%">
                <div style="font-size:11px;color:var(--text-muted);margin-bottom:10px">또는 데모 화면 둘러보기</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;max-width:340px;margin:0 auto">
                    @foreach (var pg in _pages)
                    {
                        var p = pg;
                        <a href="@p.Href" style="text-decoration:none">
                            <div style="background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius);padding:12px;text-align:center">
                                <div style="font-size:22px">@p.Icon</div>
                                <div style="font-size:11px;color:var(--text-dim);margin-top:4px">@p.Name</div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- 데이터 로드됨 — 게임 허브 -->
        <div style="padding:16px;display:flex;flex-direction:column;gap:16px">

            <div style="background:linear-gradient(135deg,#1a1020 0%,#0d0d18 100%);border-radius:var(--radius);padding:16px;border:1px solid var(--border)">
                <div style="display:flex;align-items:center;gap:12px">
                    <div style="font-size:40px">🧝</div>
                    <div>
                        <div style="font-size:16px;font-weight:700;color:var(--text)">플레이어</div>
                        <div style="font-size:12px;color:var(--accent)">Lv.@GSS.Level · EXP @GSS.Exp/@GSS.NextExp</div>
                        <div style="font-size:11px;color:var(--text-dim);margin-top:2px">
                            HP @GSS.Hp/@GSS.MaxHp · 정신력 @GSS.Mental/@GSS.MaxMental
                        </div>
                    </div>
                </div>
            </div>

            <!-- 메인 액션 -->
            @if (GDS.Data!.GameEvents.Count > 0)
            {
                <button class="game-btn" style="width:100%;padding:14px;font-size:15px;display:flex;align-items:center;justify-content:center;gap:8px" @onclick="GoToEvent">
                    <span>📜</span> 이벤트 진행하기
                </button>
            }
            @if (GDS.Data!.BattleDatas.Count > 0)
            {
                <button class="game-btn secondary" style="width:100%;padding:13px;display:flex;align-items:center;justify-content:center;gap:8px" @onclick="GoToBattle">
                    <span>⚔️</span> 전투 시작
                </button>
            }

            <!-- 화면 목록 -->
            <div>
                <div class="section-title">화면</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
                    @foreach (var pg in _pages)
                    {
                        var p = pg;
                        <a href="@p.Href" style="text-decoration:none">
                            <div style="background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius);padding:14px;display:flex;gap:10px;align-items:center">
                                <div style="font-size:22px">@p.Icon</div>
                                <div>
                                    <div style="font-size:13px;font-weight:700;color:var(--text)">@p.Name</div>
                                    <div style="font-size:10px;color:var(--text-muted)">@p.Desc</div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>

            <!-- 데이터 요약 -->
            <div>
                <div class="section-title">로드된 데이터</div>
                <div style="background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius);padding:12px;display:grid;grid-template-columns:repeat(3,1fr);gap:8px;text-align:center">
                    @foreach (var (label, count) in new (string, int)[]
                    {
                        ("이벤트", GDS.Data!.GameEvents.Count),
                        ("아이템", GDS.Data!.GameItems.Count),
                        ("유닛",   GDS.Data!.GameUnits.Count),
                    })
                    {
                        <div>
                            <div style="font-size:16px;font-weight:700;color:var(--accent)">@count</div>
                            <div style="font-size:10px;color:var(--text-muted)">@label</div>
                        </div>
                    }
                </div>
            </div>

            <button class="game-btn secondary" style="width:100%;font-size:12px" @onclick='() => Nav.NavigateTo("/import")'>
                📦 다른 데이터 불러오기
            </button>
        </div>
    }
</div>

@code {
    record PageLink(string Href, string Icon, string Name, string Desc);
    readonly List<PageLink> _pages = new()
    {
        new("/event",     "📜", "이벤트",   "서사·대화·선택지"),
        new("/battle",    "⚔️", "전투",     "턴제 전투"),
        new("/inventory", "🎒", "인벤토리", "아이템 목록"),
        new("/equipment", "🛡️", "장비",     "7슬롯 장착"),
        new("/status",    "📊", "스탯",     "능력치·바이탈"),
    };

    void GoToEvent()
    {
        GSS.CurrentEventKey = GDS.FirstEventKey();
        Nav.NavigateTo("/event");
    }

    void GoToBattle()
    {
        GSS.PendingBattleKey = GDS.FirstBattleKey();
        Nav.NavigateTo("/battle");
    }
}
